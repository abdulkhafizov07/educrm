# Copy to .env and adjust. Do NOT commit .env.
# cp .env.example .env

# ---------------------------------------------------
# Postgres (used by the `postgres` service)
# ---------------------------------------------------
POSTGRES_USER=educrm
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=educrm
# Host port to publish postgres on
POSTGRES_PORT=5432

# ---------------------------------------------------
# Auth secrets (used by the `api` service)
# Generate strong values: openssl rand -hex 32
# ---------------------------------------------------
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------
# Networking / published host ports
# ---------------------------------------------------
WEB_PORT=12046
API_PORT=4000

# Where the browser reaches the API (defaults to http://localhost:${API_PORT})
NEXT_PUBLIC_API_URL=http://localhost:4000
# Browser origin allowed by the API CORS (defaults to http://localhost:${WEB_PORT})
CORS_ORIGIN=http://localhost:12046
